    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHf3lUsQeSvJlhfocigJIwBZboQ2QEQntBGvR2kNY5Q593PfLEkuXJuuaDtDBfcuJk-G7NofEuyhSRiSAb08TwZHslqT8MFyAxJsTnAwFG_XebuqieJ_Gyv0h0vjghZ2TCJSWFkfwG9S9XHju9_U938PObpYvSiQQ5hYJHKJdeA8sqfV7PseOXaew=="
      title: "lobehub.com"
