    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH8qvvNaq83NHzq3W2jEeghBXKQBZMjeFJabTXBdVagoOxlR-8LHWvDATwmxc2ZSbmuLOTRrbt4_qJpJsoxsvVsj3Ocp275hY6TIKKUXJf20-ok8ioFcy042ykp-PKTp1GD0rpOTl5HisFahwG4dKSsFvqHmR3P2Ew_zTTz5HfT0xoAnMKyGvSGB4K-kpMopHl8UBydYb518Q=="
