    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE2MjrWtdHZr5mt5-VaZvylp41dE08TkThsHDJhk4g6d15vrS7UYmvD_uWy4Cc-3LMHx-RQBbIutx5Bhp4pcWVkIM0JZe-ASim2nrqLTWUhV9_undFF8LcxAvplF8qy9jyAupjTA3OceA9XCrrkgQ=="
