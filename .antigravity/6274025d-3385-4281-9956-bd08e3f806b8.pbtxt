    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHdECOHmSx86ghl6KbEtVuWMCLtc-IZjqVnJrj9SVHSqQiIOcUGbezdFo6F82T4dvlpTM6AprJv33SjXOhDxLDVkiJUjugeVXKwmoOmpbvaIZesGt3OoVfhVB1pYtttqAzHoF_vJ-3tuKqXrX4="
