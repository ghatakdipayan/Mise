ntent not found in file\n    \342\224\224\342\224\200 Wraps: (5) attached stack trace\n  -- stack trace:\n  | google3/third_party/gemini_coder/framework/handlers/applyedit/applyedit.applyApplicableChunksToContent\n  | \tthird_party/gemini_coder/framework/handlers/applyedit/apply_edit.go:351\n  | google3/third_party/gemini_coder/framework/handlers/applyedit/applyedit.HandleReplaceFileContentWithFallback\n  | \tthird_party/gemini_coder/framework/handlers/applyedit/apply_edit.go:118\n  | google3/third_party/gemini_coder/framework/handlers/handlers.(*FileChangeHandler).handleEdit\n  | \tthird_party/gemini_coder/framework/handlers/file_change.go:212\n  | google3/third_party/gemini_coder/framework/handlers/handlers.(*FileChangeHandler).Handle\n  | \tthird_party/gemini_coder/framework/handlers/file_change.go:82\n  | google3/third_party/gemini_coder/framework/executor/executor.(*Executor).handleStep\n  | \tthird_party/gemini_coder/framework/executor/executor.go:236\n  | google3/devtools/jetski/boq/agent_service/agent.(*SectionBasedMixin).HandlerDecorators.NewStepMetricsDecorator.func1.1\n  | \tdevtools/jetski/boq/agent_service/step_metrics_decorator.go:24\n  | google3/third_party/gemini_coder/framework/executor/executor.(*ExecutionWrapper).asyncHandleStep.func3\n  | \tthird_party/gemini_coder/framework/executor/execution_wrapper.go:300\n  | google3/go/context/detach.Go.func1\n  | \tgo/context/detach.go:250\n  | runtime.goexit\n  | \tthird_party/go/gc/src/runtime/asm_amd64.s:1736\n      \342\224\224\342\224\200 Wraps: (6) chunk 0\n        \342\224\224\342\224\200 Wraps: (7)\n          \342\224\224\342\224\200 Wraps: (8) target content not found in file\nError types: (1) *withstack.withStack (2) *errutil.withPrefix (3) *withstack.withStack (4) *join.joinError (5) *withstack.withStack (6) *errutil.withPrefix (7) *applyedit.repairFixableError (8) *applyedit.fastApplyFixableError"
