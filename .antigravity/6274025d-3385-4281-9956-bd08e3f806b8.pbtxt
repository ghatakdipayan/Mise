    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEtJ45FvZjrfwstHIVPb1xaGSQ3juKbCzmRX3AeYfY4CeyDfOjqLg921NKD-Fvi2b_-fDzoeH2KS3vVZNO7tuKIpe2jzM2PA9MI95f5813KyD2uHhzjdbwg_D6XSujV1nEl4i04shgiBR0ZmRg2CZKLKJ9CAXm8Zf4D"
