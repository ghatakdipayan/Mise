    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFCbs0uHLxnBIJIH5mrAfTVot5yu_egL40YmVMMK65yjA5aIkolQK27Flp_8hfKKW2NbYNFRZU8qoSH60C5ygyMSfiIxz8_rEwDHKmjNMxghbNqSWcQo2dxeOIVhLlhnKH3vscSTGFqQ1G6kMWXjtx6Bdpmliijut-GiCIAFKQBUAA9ZNdqk_QzjwFlezri7kmcq--Qv9Z9Y6AGkhDUGKi6X-YMZQpkQIRWu4y-JWY="
